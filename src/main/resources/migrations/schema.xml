  <changeSet author="Bogdan Jovanovic" id="schemaInit_action">
    <sql>
      CREATE TYPE action AS ENUM('ALLOW', 'DENY');
      CREATE CAST (character varying AS action) WITH INOUT AS IMPLICIT;
    </sql>
    <rollback>
      <sql>
        DROP CAST (character varying AS action);
        DROP TYPE action;
      </sql>
    </rollback>
  </changeSet>

  <changeSet author="Bogdan Jovanovic" id="schemaInit_createRuleTable">
    <createTable tableName="rule">
      <column name="rule_id" type="bigserial">
        <constraints primaryKey="true"/>
      </column>
      <column name="src_start" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="src_end" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="dest_start" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="dest_end" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="action" type="action">
        <constraints nullable="false"/>
      </column>
      <column name="version" type="bigint">
        <constraints nullable="false"/>
      </column>
    </createTable>

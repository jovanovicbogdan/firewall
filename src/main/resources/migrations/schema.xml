<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:pro="http://www.liquibase.org/xml/ns/pro"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
    http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-latest.xsd ">

  <changeSet author="Bogdan Jovanovic" id="schemaInit_action">
    <sql>
      CREATE TYPE action AS ENUM('ALLOW', 'DENY');
      CREATE CAST (character varying AS action) WITH INOUT AS IMPLICIT;
    </sql>
    <rollback>
      <sql>
        DROP CAST (character varying AS action);
        DROP TYPE action;
      </sql>
    </rollback>
  </changeSet>

  <changeSet author="Bogdan Jovanovic" id="schemaInit_createRuleTable">
    <createTable tableName="rule">
      <column name="rule_id" type="bigserial">
        <constraints primaryKey="true"/>
      </column>
      <column name="src_start" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="src_end" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="dest_start" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="dest_end" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column name="action" type="action">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <createIndex tableName="rule" indexName="idx_rule_src_start_src_end_dest_start_dest_end">
      <column name="src_start"/>
      <column name="src_end"/>
      <column name="dest_start"/>
      <column name="dest_end"/>
    </createIndex>
  </changeSet>

  <changeSet author="Bogdan Jovanovic" id="schemaInit_createNotifyRuleChangeTrigger">
    <sql splitStatements="false">
      CREATE OR REPLACE FUNCTION notify_rule_change() RETURNS trigger AS $notify_rule_change$
      BEGIN
        PERFORM pg_notify('rule_events', '');
        RETURN NULL;
      END;
      $notify_rule_change$ LANGUAGE plpgsql;
    </sql>
    <sql>
      CREATE TRIGGER notify_rule_change
      AFTER INSERT OR UPDATE OR DELETE ON rule
      FOR EACH STATEMENT
      EXECUTE FUNCTION notify_rule_change();
    </sql>
    <rollback>
      <sql>DROP TRIGGER IF EXISTS notify_rule_change ON rule;</sql>
      <sql>DROP FUNCTION IF EXISTS notify_rule_change();</sql>
    </rollback>
  </changeSet>
</databaseChangeLog>
